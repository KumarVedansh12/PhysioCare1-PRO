# Generate a strong value; never commit the real secret.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=physiocare.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://physiocare.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://physiocare.example.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_HSTS_SECONDS=31536000
DJANGO_LOG_LEVEL=INFO

# Supabase Dashboard → Connect → Session pooler (recommended for Gunicorn/Django).
# Percent-encode special characters in the password if you construct the URI manually.
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_CONNECT_TIMEOUT=10
POSTGRES_CONN_MAX_AGE=60

# Optional hosted storage and SMTP configuration.
CLOUDINARY_URL=
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=PhysioCare <care@example.com>
