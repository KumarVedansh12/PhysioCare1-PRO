# Generate a strong value; never commit the real secret.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=physiocare.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://physiocare.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://physiocare.example.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_HSTS_SECONDS=31536000
DJANGO_LOG_LEVEL=INFO

# Supabase Dashboard → Connect → Session pooler (recommended for Gunicorn/Django).
# Percent-encode special characters in the password if you construct the URI manually.
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_CONNECT_TIMEOUT=10
POSTGRES_CONN_MAX_AGE=60

# Public application URL used in email buttons and reset links.
SITE_URL=https://physiocare.example.com

# Optional hosted storage.
CLOUDINARY_URL=
MAX_PRIVATE_UPLOAD_MB=10

# Required for encrypted .pcbackup exports. Generate once and store securely:
# python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
BACKUP_ENCRYPTION_KEY=replace-with-a-fernet-compatible-key

# SMTP email. Keep disabled until every value below has been replaced and tested.
# Set EMAIL_USE_TLS=1 for port 587, or EMAIL_USE_SSL=1 for port 465.
EMAIL_ENABLED=0
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST_USER=your-smtp-login@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_TIMEOUT=15
EMAIL_MAX_ATTEMPTS=5
DEFAULT_FROM_EMAIL=PhysioCare <care@example.com>
SERVER_EMAIL=PhysioCare <care@example.com>
CONTACT_EMAIL=care@example.com
EMAIL_REPLY_TO=care@example.com

# Email verification and appointment reminder worker.
OTP_EXPIRY_MINUTES=10
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5
REMINDER_POLL_SECONDS=60
